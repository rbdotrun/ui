<div id="rbrun-ui-flash-tray"
     class="pointer-events-none fixed bottom-4 right-4 z-50 flex w-[min(22rem,calc(100vw-2rem))] flex-col gap-3 sm:bottom-6 sm:right-6">
  <% flash.each do |type, message| %>
    <%= render "rbrun_ui/shared/flash", type:, message: %>
  <% end %>

  <% if local_assigns.fetch(:include_demo_stream, false) %>
    <%= turbo_stream_from "rbrun-ui-flash-demo" %>
    <div id="rbrun-ui-flash-demo-tray" class="contents"></div>
  <% end %>
</div>
