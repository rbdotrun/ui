<% content_for :title, "Component showcase" %>
<% content_for :flash_demo_stream, true %>

<div class="mx-auto max-w-5xl px-6 py-10">
  <header>
    <h1 class="text-2xl font-semibold text-stone-900">Component showcase</h1>
    <p class="mt-1 text-sm text-stone-500">
      Dev-only. One section per component the design system ships.
      If it breaks here, it breaks everywhere.
    </p>
  </header>

  <section class="mt-10">
    <h2 class="text-lg font-semibold text-stone-900">Button</h2>
    <%= render "button" %>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-stone-900">Avatar</h2>
    <%= render "avatar" %>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-stone-900">Badge</h2>
    <%= render "badge" %>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-stone-900">Alert</h2>
    <%= render "alert" %>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-stone-900">Flash</h2>
    <%= render "flash" %>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-stone-900">Item</h2>
    <%= render "item" %>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-stone-900">Popover</h2>
    <%= render "popover" %>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-stone-900">Menu</h2>
    <%= render "menu" %>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-stone-900">Select</h2>
    <%= render "select" %>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-stone-900">Card</h2>
    <%= render "card" %>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-stone-900">Table</h2>
    <%= render "table" %>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-stone-900">Dialog</h2>
    <%= render "dialog" %>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-stone-900">Drawer</h2>
    <%= render "drawer" %>
  </section>
</div>
